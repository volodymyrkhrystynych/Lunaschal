# Copy this file to .env and fill in your values.

# ── LLM provider (pick one, or configure via the Settings UI) ──────────────
OPENAI_API_KEY=
# GOOGLE_API_KEY=

# ── Voice assistant backends ───────────────────────────────────────────────
# local  → faster-whisper (GPU) + kokoro-onnx (CPU); run: bash stt/setup.sh
# openai → OpenAI Whisper + TTS API;                 run: bash stt/setup.sh --api
STT_BACKEND=openai
TTS_BACKEND=openai

# OpenAI TTS voice: alloy | echo | fable | onyx | nova | shimmer
OPENAI_TTS_VOICE=nova

# ── Local STT options (only used when STT_BACKEND=local) ───────────────────
# WHISPER_MODEL=large-v3-turbo
# WHISPER_DEVICE=cuda

# ── Wake word (optional) ───────────────────────────────────────────────────
# WAKE_WORD_MODEL=stt/models/hey_luna.onnx
# WAKE_WORD_THRESHOLD=0.5

# ── Server ─────────────────────────────────────────────────────────────────
# PORT=3000
# DATABASE_URL=./data/lunaschal.db
# JWT_SECRET=change-me-in-production
