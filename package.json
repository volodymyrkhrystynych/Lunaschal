{
  "name": "lunaschal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:flask\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:flask": ".venv/bin/flask --app backend.app run --port 5000 --debug",
    "dev:desktop": "python main.py --dev",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:backend": ".venv/bin/pytest",
    "test:all": "npm run test:backend && npm run test",
    "stt": "./stt/run_listener.sh",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "simple-git-hooks"
  },
  "lint-staged": {
    "**/*": "prettier --ignore-unknown --write"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@replit/codemirror-vim": "^6.3.0",
    "@tanstack/react-query": "^5.90.20",
    "codemirror": "^6.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "concurrently": "^9.2.1",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3",
    "simple-git-hooks": "^2.11.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.9"
  }
}
